# ─── Model Configuration ───────────────────────────────────────────
# Any HuggingFace decoder-only causal LM works here.
# Examples:
#   TinyLlama/TinyLlama-1.1B-Chat-v1.0
#   Qwen/Qwen2-0.5B
#   microsoft/phi-2
#   meta-llama/Llama-2-7b-chat-hf    (requires HF token)
#   mistralai/Mistral-7B-Instruct-v0.2
#   google/gemma-2b-it
MODEL_NAME=TinyLlama/TinyLlama-1.1B-Chat-v1.0

# HuggingFace token for gated models (Llama, Gemma, etc.)
# Get yours at https://huggingface.co/settings/tokens
HF_TOKEN=

# ─── Cache Settings ────────────────────────────────────────────────
# Chunk size in tokens. Smaller = higher hit rate, larger = less overhead.
CHUNK_SIZE=64

# Max chunks to hold in RAM before LRU eviction kicks in.
MAX_CHUNKS=128

# Tokens to recompute at each chunk boundary seam for correctness.
RECOMPUTE_OVERLAP=8

# Optional: directory for disk-backed cold storage (tier 2 cache).
# Leave empty to disable disk caching.
DISK_CACHE_DIR=

# ─── Generation Settings ──────────────────────────────────────────
MAX_NEW_TOKENS=64
TEMPERATURE=1.0
DO_SAMPLE=false

# ─── Device Override ──────────────────────────────────────────────
# Auto-detected if empty. Options: cuda, mps, cpu
DEVICE=
